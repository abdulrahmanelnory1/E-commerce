{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "filament/filament": "*",
        "laravel/framework": "^12.0",
        "laravel/socialite": "^5.25",
        "laravel/tinker": "^2.10.1",
        "livewire/livewire": "^4.2",
        "mhmiton/laravel-modules-livewire": "^7.0",
        "nwidart/laravel-modules": "^13.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/breeze": "^2.4",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Modules\\Category\\App\\": "Modules/Category/app/",
            "Modules\\Category\\Database\\Factories\\": "Modules/Category/database/factories/",
            "Modules\\Category\\Database\\Seeders\\": "Modules/Category/database/seeders/",
            "Modules\\Category\\Providers\\": "Modules/Category/Providers/",
            "Modules\\Category\\Tests\\": "Modules/Category/tests/",
            "Modules\\SubCategory\\App\\": "Modules/SubCategory/app/",
            "Modules\\SubCategory\\Database\\Factories\\": "Modules/SubCategory/database/factories/",
            "Modules\\SubCategory\\Database\\Seeders\\": "Modules/SubCategory/database/seeders/",
            "Modules\\SubCategory\\Providers\\": "Modules/SubCategory/Providers/",
            "Modules\\SubCategory\\Tests\\": "Modules/SubCategory/tests/",
            "Modules\\Product\\App\\": "Modules/Product/app/",
            "Modules\\Product\\Database\\Factories\\": "Modules/Product/database/factories/",
            "Modules\\Product\\Database\\Seeders\\": "Modules/Product/database/seeders/",
            "Modules\\Product\\Providers\\": "Modules/Product/Providers/",
            "Modules\\Product\\Tests\\": "Modules/Product/tests/",
            "Modules\\Cart\\App\\": "Modules/Cart/app/",
            "Modules\\Cart\\Database\\Factories\\": "Modules/Cart/database/factories/",
            "Modules\\Cart\\Database\\Seeders\\": "Modules/Cart/database/seeders/",
            "Modules\\Cart\\Providers\\": "Modules/Cart/Providers/",
            "Modules\\Cart\\Tests\\": "Modules/Cart/tests/",
            "Modules\\Frontend\\App\\": "Modules/Frontend/app/",
            "Modules\\Frontend\\Database\\Factories\\": "Modules/Frontend/database/factories/",
            "Modules\\Frontend\\Database\\Seeders\\": "Modules/Frontend/database/seeders/",
            "Modules\\Frontend\\Providers\\": "Modules/Frontend/Providers/",
            "Modules\\Frontend\\Tests\\": "Modules/Frontend/tests/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "audit": {
        "ignore": [
            "PKSA-5bdf-2x61-v43c"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
